# Copy this file to .env.local and fill in your own values.
# .env.local is already excluded from version control (see .gitignore).

# RentCast API key. Get one at https://app.rentcast.io/app/api
# Server-only — never exposed to the browser. Leave blank to stay in demo mode.
RENTCAST_API_KEY=

# "rentcast" to use real property data (requires RENTCAST_API_KEY above),
# or "demo" to always use deterministic simulated data. Defaults to "demo"
# if unset or set to anything else.
PROPERTY_DATA_MODE=demo
