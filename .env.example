# Copy this file to .env.local and fill in your own values.
# .env.local is already excluded from version control (see .gitignore).

# RentCast API key. Get one at https://app.rentcast.io/app/api
# Server-only — never exposed to the browser. Leave blank to stay in demo mode.
RENTCAST_API_KEY=

# "rentcast" to use real property data (requires RENTCAST_API_KEY above),
# or "demo" to always use deterministic simulated data. Defaults to "demo"
# if unset or set to anything else.
PROPERTY_DATA_MODE=demo

# --- Investment Analyst (AI-assisted deal explanation) ---
# Optional. Leave all three blank to use the built-in rule-based analyst,
# which works fully offline and never calls a third-party AI API.
# Server-only — never exposed to the browser.

# "anthropic" or "openai". Any other value (or leaving this blank) disables
# AI analysis and falls back to the rule-based analyst automatically.
AI_PROVIDER=

# API key for the provider above. Get one at
# https://console.anthropic.com/settings/keys (Anthropic) or
# https://platform.openai.com/api-keys (OpenAI).
AI_API_KEY=

# Model name for the configured provider. Leave blank to use a sensible
# default (claude-sonnet-5 for Anthropic, gpt-4o-mini for OpenAI).
AI_MODEL=

# --- Supabase (cloud auth + cloud data storage) ---
# Project Settings -> API in the Supabase dashboard.
# The anon/publishable key is safe to expose to the browser by design (all
# access is gated by row-level security) — never put the service_role/secret
# key here or in any NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
